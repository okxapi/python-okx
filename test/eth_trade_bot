        log_action("系统启动", "=" * 80)

        loop.run_until_complete(core_strategy_loop())
    except KeyboardInterrupt:
        log_action("系统", "用户中断程序", "info")
    except Exception as e:
        log_action("系统", f"未处理异常: {str(e)}", "critical", exc_info=True)
